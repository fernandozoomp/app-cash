# ============================================================================
# EXEMPLO DE VARIÁVEIS DE AMBIENTE — não preencha este arquivo!
# ============================================================================
# Copie este arquivo para ".env.local" e preencha com seus dados reais.
# O arquivo .env.local NUNCA vai para o GitHub (está no .gitignore).
#
# COMO OBTER OS VALORES (painel novo do Supabase 2025/2026):
#   1. Acesse https://supabase.com/dashboard
#   2. Selecione seu projeto "meu-caixa"
#   3. No menu: Project Settings (ícone de engrenagem ⚙️) → API
#   4. Você verá duas chaves:
#        - "Publishable key"  → copie em NEXT_PUBLIC_SUPABASE_ANON_KEY
#        - "Secret key"       → NÃO use no app (é a chave-mestra)

# URL pública do projeto (não é segredo — aparece no navegador)
# Em "Project URL" no painel, copie o valor de "Project URL"
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Publishable key (antiga "anon key").
# É SEGURA para o navegador porque todas as tabelas têm RLS ativado.
# Cole aqui o valor que aparece como "Publishable key" no painel.
NEXT_PUBLIC_SUPABASE_ANON_KEY=cole-aqui-sua-publishable-key
